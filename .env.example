# Copy this file to .env and fill in the values before running docker-compose

# PostgreSQL
POSTGRES_DB=MarketLinkDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here

# JWT
JWT_SECRET=MarketLink_SuperSecretKey_Min32Chars_ChangeThis!
JWT_ISSUER=MarketLink
JWT_AUDIENCE=MarketLink

# Eskiz SMS (https://eskiz.uz)
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your_eskiz_password

# MinIO
MINIO_USER=minioadmin
MINIO_PASSWORD=your_minio_password
MINIO_PUBLIC_URL=http://your-server-ip:9000

# API
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Production
